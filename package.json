{
  "name": "spacetimedb-mcp",
  "version": "1.0.0",
  "description": "Universal SpacetimeDB MCP Server - Convex-level developer experience",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "spacetimedb-mcp": "./dist/bundle.sh"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js dist/index.sh",
    "bundle": "node build.mjs",
    "dev": "tsc --watch",
    "prepare": "npm run build && npm run bundle",
    "postinstall": "chmod +x dist/index.js dist/index.sh dist/bundle.js",
    "prepublishOnly": "npm run build",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "smoke": "node scripts/smoke_test.mjs"
  },
  "keywords": [
    "mcp",
    "spacetimedb",
    "mcp-server",
    "database",
    "debugging"
  ],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "esbuild": "^0.27.3",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
