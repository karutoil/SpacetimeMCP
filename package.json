{
  "name": "spacetimedb-mcp",
  "version": "1.0.0",
  "description": "Universal SpacetimeDB MCP Server - Convex-level developer experience",
  "main": "dist/index.js",
  "type": "module",
  "bin": {
    "spacetimedb-mcp": "./dist/index.sh"
  },
  "scripts": {
    "build": "tsc && chmod +x dist/index.js dist/index.sh",
    "dev": "tsc --watch",
    "prepare": "npm run build",
    "postinstall": "chmod +x dist/index.js dist/index.sh",
    "prepublishOnly": "npm run build",
    "test": "node --experimental-vm-modules node_modules/jest/bin/jest.js",
    "smoke": "node scripts/smoke_test.mjs"
  },
  "keywords": ["mcp", "spacetimedb", "mcp-server", "database", "debugging"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.0"
  },
  "devDependencies": {
    "@types/node": "^20.0.0",
    "typescript": "^5.0.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
